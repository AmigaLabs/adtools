From 45c2e79dfd34ccf7ad59e52ea7be620ae32eba04 Mon Sep 17 00:00:00 2001
From: Georgios Sokianos <walkero@gmail.com>
Date: Tue, 10 Mar 2026 22:58:48 +0000
Subject: [PATCH 43/43] Fixing c++ exceptions with dwarf 2

---
 gcc/config/rs6000/amigaos.h | 11 ++++++++++-
 libgcc/config.host          |  6 +++++-
 2 files changed, 15 insertions(+), 2 deletions(-)

diff --git a/gcc/config/rs6000/amigaos.h b/gcc/config/rs6000/amigaos.h
index 1256bd92425e397a0dd7a13bb8df674192c9cd9b..987d5cff3b2c15aa96cca905ddb8fd9cb396c7ff 100644
--- a/gcc/config/rs6000/amigaos.h
+++ b/gcc/config/rs6000/amigaos.h
@@ -488,7 +488,16 @@ do                                   \
 //   || (((MODE) == SFmode) && (ALIGN) < 32)				\
 //   || (((MODE) == DFmode || (MODE) == TFmode || (MODE) == DImode)	\
 //       && (ALIGN) < 64))
 */
 
 /* This target uses the amigaos.opt file.  */
-#define TARGET_USES_AMIGAOS_OPT 1
\ No newline at end of file
+#define TARGET_USES_AMIGAOS_OPT 1
+
+/* Enable DWARF2 exception handling.  Ensures the compiler emits .eh_frame
+   and uses the DWARF2 unwinder so C++ exceptions work with libgcc unwind-dw2.  */
+#define DWARF2_UNWIND_INFO 1
+
+/* Enable DWARF2 object end pointer extension.  This allows the compiler to emit
+   the end pointer for the .eh_frame section.  This is necessary for the DWARF2
+   unwinder to work correctly.  */
+#define DWARF2_OBJECT_END_PTR_EXTENSION 1
\ No newline at end of file
diff --git a/libgcc/config.host b/libgcc/config.host
index 1314e6523aa88040c990f076098074bc335c1037..4bd834396deac663e8c818171bc92e5af9c2dda5 100644
--- a/libgcc/config.host
+++ b/libgcc/config.host
@@ -1159,13 +1159,17 @@ or1k-*-*)
 	tmake_file="$tmake_file t-softfp-sfdf t-softfp"
 	;;
 pdp11-*-*)
 	tmake_file="pdp11/t-pdp11 t-fdpbit"
 	;;
 powerpc-*-amigaos*)
-	tmake_file="${tmake_file} rs6000/t-savresfgpr rs6000/t-amigaos"
+	tmake_file="${tmake_file} rs6000/t-savresfgpr rs6000/t-amigaos t-eh-dw2-dip"
+	# Install crtbegin/crtend so they can be deployed to SDK newlib for C++
+	# DWARF2 exception handling. These files will be copied to
+	# $(SDKROOT)/ppc-amigaos/SDK/newlib/lib/ during SDK packaging.
+	extra_parts="$extra_parts crtbegin.o crtend.o crtbeginS.o crtendS.o"
 	;;
 powerpc-*-darwin*)
 	case ${host} in
 	*-*-darwin9* | *-*-darwin[12][0-9]*)
 	  # libSystem contains unwind information for signal frames since
 	  # Darwin 9.
-- 
2.43.0

