 2 files changed, 4 insertions(+), 1 deletion(-)

diff --git a/gcc/config/rs6000/amigaos.c b/gcc/config/rs6000/amigaos.c
index 8cc91122359e31451d39f486a1c9fbec449918a4..209ae8ed460b4b36dd0a3efd8e48148c8accb40c 100644
--- a/gcc/config/rs6000/amigaos.c
+++ b/gcc/config/rs6000/amigaos.c
@@ -20,12 +20,13 @@
    MA 02111-1307, USA.  */
 
 
 #include "config.h"
 #include "system.h"
 #include "coretypes.h"
+#include "memmodel.h"
 #include "diagnostic-core.h"
 #include "tm.h"
 #include "hash-set.h"
 #include "inchash.h"
 #include "rtl.h"
 #include "regs.h"
@@ -37,12 +38,14 @@
 #include "insn-attr.h"
 #include "flags.h"
 #include "recog.h"
 #include "obstack.h"
 #include "symtab.h"
 #include "tree.h"
