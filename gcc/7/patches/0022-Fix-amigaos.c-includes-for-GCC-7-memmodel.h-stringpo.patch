 #include "optabs.h"
 #include "except.h"
 #include "function.h"
 #include "output.h"
 #include "tm_p.h"
diff --git a/gcc/config/rs6000/amigaos.h b/gcc/config/rs6000/amigaos.h
index a212fbcd749337840cb529fb7d8d4f1e16f9ab2e..3db80cb7f256f49721009d16508d2185c050533e 100644
