From 5d63fe1bc75ee75a02a074a9148f4156e9428f48 Mon Sep 17 00:00:00 2001
From: Richard Gibbs <rich_gibbs@hotmail.com>
Date: Sat, 28 Mar 2026 01:32:13 +0000
Subject: [PATCH 07/25] Added e500 support for AmigaOS.

---
 gcc/config.gcc                                           | 2 +-
 libstdc++-v3/config/os/{generic => amigaos}/ctype_base.h | 0
 2 files changed, 1 insertion(+), 1 deletion(-)
 copy libstdc++-v3/config/os/{generic => amigaos}/ctype_base.h (100%)

diff --git a/gcc/config.gcc b/gcc/config.gcc
index 6d91ea7f31705cb26ce02a70316114b249134323..a35b31024144efbe3dd9ce4741c0362f4a1a8fd7 100644
--- a/gcc/config.gcc
+++ b/gcc/config.gcc
@@ -2347,13 +2347,13 @@ nvptx-*)
 	;;
 pdp11-*-*)
 	tm_file="${tm_file} newlib-stdint.h"
 	use_gcc_stdint=wrap
 	;;
 powerpc-*-amigaos*)
-	tm_file="${tm_file} dbxelf.h elfos.h rs6000/sysv4.h rs6000/amigaos.h"
+	tm_file="${tm_file} dbxelf.h elfos.h rs6000/sysv4.h rs6000/amigaos.h rs6000/e500.h"
 	tm_p_file="${tm_p_file} rs6000/amigaos-protos.h"
 	extra_options="${extra_options} rs6000/sysv4.opt rs6000/amigaos.opt"
 	tmake_file="rs6000/t-amigaos"
 	extra_objs=amigaos.o
 	use_collect2=no
 	;;
diff --git a/libstdc++-v3/config/os/generic/ctype_base.h b/libstdc++-v3/config/os/amigaos/ctype_base.h
similarity index 100%
copy from libstdc++-v3/config/os/generic/ctype_base.h
copy to libstdc++-v3/config/os/amigaos/ctype_base.h
-- 
