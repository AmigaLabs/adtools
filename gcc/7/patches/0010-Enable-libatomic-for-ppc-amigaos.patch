   { return __gnu_cxx::__stoa(&std::strtof, "stof", __str.c_str(), __idx); }
 
   inline double
   stod(const string& __str, size_t* __idx = 0)
   { return __gnu_cxx::__stoa(&std::strtod, "stod", __str.c_str(), __idx); }
 
