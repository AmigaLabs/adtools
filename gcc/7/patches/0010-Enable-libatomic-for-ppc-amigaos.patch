 #define _GLIBCXX_NO_IOCTL 1
 
 #ifdef __NEWLIB__
 #define _GLIBCXX_USE_C99_STDINT_TR1 1
+#define _GLIBCXX_USE_C99 1
+/* Temporary until newlib behaves properly */
