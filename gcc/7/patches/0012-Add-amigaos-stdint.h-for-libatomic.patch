From 89b50627c8b74c1030628072e44835d3806066e7 Mon Sep 17 00:00:00 2001
From: Richard Gibbs <rich_gibbs@hotmail.com>
Date: Sat, 28 Mar 2026 08:39:38 +0000
Subject: [PATCH 12/25] Add amigaos-stdint.h for libatomic.

---
 gcc/config.gcc              | 2 +-
 gcc/config/amigaos-stdint.h | 3 ++-
 2 files changed, 3 insertions(+), 2 deletions(-)

diff --git a/gcc/config.gcc b/gcc/config.gcc
index a35b31024144efbe3dd9ce4741c0362f4a1a8fd7..9b9d1b9b1886fcd38a44e6cb968156b64e42842f 100644
--- a/gcc/config.gcc
+++ b/gcc/config.gcc
@@ -2347,13 +2347,13 @@ nvptx-*)
 	;;
 pdp11-*-*)
 	tm_file="${tm_file} newlib-stdint.h"
 	use_gcc_stdint=wrap
 	;;
 powerpc-*-amigaos*)
-	tm_file="${tm_file} dbxelf.h elfos.h rs6000/sysv4.h rs6000/amigaos.h rs6000/e500.h"
+	tm_file="${tm_file} dbxelf.h elfos.h amigaos-stdint.h rs6000/sysv4.h rs6000/amigaos.h rs6000/e500.h"
 	tm_p_file="${tm_p_file} rs6000/amigaos-protos.h"
 	extra_options="${extra_options} rs6000/sysv4.opt rs6000/amigaos.opt"
 	tmake_file="rs6000/t-amigaos"
 	extra_objs=amigaos.o
 	use_collect2=no
 	;;
diff --git a/gcc/config/amigaos-stdint.h b/gcc/config/amigaos-stdint.h
index 0b8b19c3daa9d4f1b12ac6d9ab74444a7ccb1cb9..c6aea218a91bb1969a7430d6baa26643a68ec82d 100644
--- a/gcc/config/amigaos-stdint.h
+++ b/gcc/config/amigaos-stdint.h
@@ -1,8 +1,9 @@
-/* Definitions for <stdint.h> types for DragonFly systems.
+/* Definitions for <stdint.h> types for AmigaOS systems.
    Copyright (C) 2014-2017 Free Software Foundation, Inc.
+   Based on the types of the dragon fly bsd that was
    Contributed by John Marino <gnugcc@marino.st>
 
