From 112238cbe0afe7065a4568a0aebca5c3bce0f05f Mon Sep 17 00:00:00 2001
From: Georgios Sokianos <walkero@gmail.com>
Date: Mon, 8 Jun 2026 22:35:54 +0000
Subject: [PATCH 3/3] native gcc13 fixes

---
 fixincludes/Makefile.in | 2 +-
 fixincludes/configure   | 1 +
 libiberty/configure     | 1 +
 libiberty/lrealpath.c   | 2 +-
 4 files changed, 4 insertions(+), 2 deletions(-)

diff --git a/fixincludes/Makefile.in b/fixincludes/Makefile.in
index 1937dcaa32d5f53b8f811d84f8836b7d5b2bce1c..a3dc056e48b6d4fe763f2fa049287b49f39137f6 100644
--- a/fixincludes/Makefile.in
+++ b/fixincludes/Makefile.in
@@ -92,13 +92,13 @@ LIBIBERTY=../libiberty/libiberty.a
 ALLOBJ = fixincl.o fixtests.o fixfixes.o server.o procopen.o \
       fixlib.o fixopts.o
 
 TESTOBJ = fixincl.o fixlib.o fixtests.o fixopts.o
 FIXOBJ  = fixfixes.o fixlib.o fixopts.o
 
-HDR = server.h fixlib.h
+HDR = config.h server.h fixlib.h
 FI  = fixincl@EXEEXT@
 AF  = applyfix@EXEEXT@
 
 all : @TARGET@ fixinc.sh mkheaders
 gen : $(srcdir)/fixincl.x
 
diff --git a/fixincludes/configure b/fixincludes/configure
index bdcc41f6ddc8d20ab8a56ee0ccc5d69cd395c469..bfd4ecff39157db83140b69d8b2eaa1f7bc87cef 100755
--- a/fixincludes/configure
+++ b/fixincludes/configure
@@ -4813,12 +4813,13 @@ else
 fi
 else
   case $host in
 	i?86-*-msdosdjgpp* | \
 	i?86-*-mingw32* | \
 	x86_64-*-mingw32* | \
+	*-*-amigaos* | \
 	*-*-beos* | \
         *-*-*vms*)
 		TARGET=twoprocess
 		;;
 
 	* )
diff --git a/libiberty/configure b/libiberty/configure
index 419701f01416a118038946c5cea57a3897e568d6..438669041e1757623c304900231060e65d39e90e 100755
--- a/libiberty/configure
+++ b/libiberty/configure
@@ -7410,12 +7410,13 @@ fi
 
 # Figure out which version of pexecute to use.
 case "${host}" in
      *-*-mingw* | *-*-winnt*)	pexecute=pex-win32  ;;
      *-*-msdosdjgpp*)		pexecute=pex-djgpp  ;;
      *-*-msdos*)		pexecute=pex-msdos  ;;
+     *-*-amigaos*)		pexecute=pex-amigaos ;;
      *)				pexecute=pex-unix   ;;
 esac
 
 
 
 
diff --git a/libiberty/lrealpath.c b/libiberty/lrealpath.c
index a283a75ae733f37d60f1df50fc7b236819ac3f72..47b291ddb7cc5ff2461c959f496e0029e792ef6c 100644
--- a/libiberty/lrealpath.c
+++ b/libiberty/lrealpath.c
@@ -234,13 +234,13 @@ lrealpath (const char *filename)
      compile time buffer size and no alternative function.  Query the
      OS, using pathconf(), for the buffer limit.  Care is needed
      though, some systems do not limit PATH_MAX (return -1 for
      pathconf()) making it impossible to pass a correctly sized buffer
      to realpath() (it could always overflow).  On those systems, we
      skip this.  */
-#if defined (HAVE_REALPATH) && defined (HAVE_UNISTD_H)
+#if !defined (REALPATH_LIMIT) && defined (HAVE_REALPATH) && defined (HAVE_UNISTD_H)
   {
     /* Find out the max path size.  */
     long path_max = pathconf ("/", _PC_PATH_MAX);
     if (path_max > 0)
       {
 	/* PATH_MAX is bounded.  */
-- 
