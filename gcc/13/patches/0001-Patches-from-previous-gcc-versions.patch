+/* CC1_SPEC (patch 0029) */
+#undef CC1_SPEC
+#define	CC1_SPEC "%{G*} %(cc1_cpu)" \
+"%{g: %{!fno-eliminate-unused-debug-symbols: -feliminate-unused-debug-symbols}} \
+%{g1: %{!fno-eliminate-unused-debug-symbols: -feliminate-unused-debug-symbols}} \
+%{msdata: -msdata=default} \
